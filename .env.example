# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- Model provider (Ch2+) ---
OPENAI_API_KEY=sk-...

# --- Tool workspace (Ch5) — the ONLY directory the file tools may touch ---
AGENT_WORKSPACE=./workspace

# --- Long-term memory / durable checkpoints (Ch6, Ch11) ---
# Postgres with the pgvector extension. Leave unset to run fully in-memory (dev).
# DATABASE_URL=postgresql://user:pass@localhost:5432/agentdb

# --- Observability (Ch9+) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
